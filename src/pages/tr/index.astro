---
import Base from '../../layouts/Base.astro';
const base = import.meta.env.BASE_URL;

const galleryFiles = await Astro.glob('../../content/tr/gallery.md');
const images: { src: string }[] = galleryFiles[0]?.frontmatter?.images ?? [];
const randomImage = images[Math.floor(Math.random() * images.length)];

const posts = await Astro.glob('../../content/tr/blog/*.md');
const latestPosts = posts
    .sort((a, b) => (a.frontmatter.date < b.frontmatter.date ? 1 : -1))
    .slice(0, 3);
---

<Base title="Yasin Şimşek" lang="tr">
  <div class="container">
    <section class="hero">
      <p class="hero-label">Portfolyo & Blog</p>
      <h1>Merhaba, ben <em>Yasin Şimşek</em></h1>
      <p>
        Blokzincir teknolojilerine ve kriptografiye meraklı bir araştırmacıyım.
      </p>
    </section>

    <div class="home-sections">
      <a href={`${base}gallery/`} class="home-section-link">
        <p class="label">Gallery</p>
        {randomImage && (
            <img
                src={`${base}${randomImage.src}`}
                alt=""
                style="width:100%;aspect-ratio:16/9;object-fit:cover;margin-top:0.75rem;"
            />
        )}
      </a>

      <div class="home-section-link" style="cursor:pointer;" onclick={`window.location='${base}blog/'`}>
        <p class="label">Latest Posts</p>
        <ul
            style={{
              listStyle: "none",
              marginTop: "0.75rem",
              display: "flex",
              flexDirection: "column",
              gap: "0.5rem",
            }}
        >
          {latestPosts.map((post) => (
              <li>
                <a href={`/blog/${post.url}`}>
                  <h3>{post.frontmatter.title}</h3>
                  <p>{post.frontmatter.description}</p>
                  <p>{post.frontmatter.date}</p>
                </a>
              </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</Base>
