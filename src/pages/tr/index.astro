---
import Base from '../../layouts/Base.astro';
const base = import.meta.env.BASE_URL;
---

<Base title="Yasin Şimşek" lang="tr">
  <div class="container">
    <section class="hero">
      <p class="hero-label">Portfolyo & Blog</p>
      <h1>Merhaba, ben<br /><em>Yasin Şimşek</em></h1>
      <p>
        Blokzincir teknolojilerine ve kriptografiye meraklı bir araştırmacıyım.
      </p>
      <a href={`${base}tr/about/`} class="btn">Hakkımda</a>
      <a href={`${base}tr/blog/`} class="btn btn-ghost">Bloğu Oku</a>
    </section>

    <div class="home-sections">
      <a href={`${base}tr/about/`} class="home-section-link">
        <p class="label">01</p>
        <h3>Hakkımda</h3>
      </a>
      <a href={`${base}tr/cv/`} class="home-section-link">
        <p class="label">02</p>
        <h3>Özgeçmiş</h3>
      </a>
      <a href={`${base}tr/blog/`} class="home-section-link">
        <p class="label">03</p>
        <h3>Blog</h3>
      </a>
    </div>
  </div>
</Base>
