---
import Base from '../layouts/Base.astro';

const files = await Astro.glob('../content/en/cv.md');
const cv = files[0];
const { Content } = cv;
---

<Base title="CV — Yasin Şimşek" lang="en">
  <div class="container">
    <header class="page-header">
      <p class="label">Curriculum Vitae</p>
      <h1>CV</h1>
    </header>
    <div class="prose">
      <Content />
    </div>
  </div>
</Base>
