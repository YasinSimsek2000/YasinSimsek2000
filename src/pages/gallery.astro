---
import Base from '../layouts/Base.astro';

// Gallery images are listed in the frontmatter of src/content/gallery.md
const files = await Astro.glob('../content/en/gallery.md');
const gallery = files[0];
const images: { src: string; caption?: string }[] = gallery?.frontmatter?.images ?? [];

const base = import.meta.env.BASE_URL;
---
<Base title="Gallery — Your Name" lang="en">
  <div class="container">
    <header class="page-header">
      <p class="label">Gallery</p>
      <h1>Gallery</h1>
      <p>A visual collection.</p>
    </header>

    {images.length === 0 && (
      <p style="color:var(--muted)">
        No images yet. Edit <code>src/content/gallery.md</code> to add images.
      </p>
    )}

    <div class="gallery-grid">
      {images.map(img => (
        <figure class="gallery-item">
          <img src={`${base}${img.src}`} alt={img.caption ?? ''} loading="lazy" />
          {img.caption && <figcaption class="gallery-caption">{img.caption}</figcaption>}
        </figure>
      ))}
    </div>
  </div>
</Base>
